<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Dónde están las librerías de Tez en HDFS
         Asumiendo que has subido tez-0.10.4.tar.gz a:
         hdfs://namenode:9000/apps/tez-0.10.4/tez-0.10.4.tar.gz
    -->
    <property>
        <name>tez.lib.uris</name>
        <value>${fs.defaultFS}/apps/tez-0.10.4/tez-0.10.4.tar.gz</value>
    </property>

    <!-- Directorio de staging de Tez en HDFS -->
    <property>
        <name>tez.staging-dir</name>
        <value>/tmp/tez/staging</value>
    </property>

    <!-- Memoria para el ApplicationMaster de Tez (AM) -->
    <property>
        <name>tez.am.resource.memory.mb</name>
        <value>512</value>
    </property>

    <!-- Opciones Java del AM (Xmx un poco menor que la memoria total) -->
    <property>
        <name>tez.am.java.opts</name>
        <value>-Xmx384m</value>
    </property>

    <!-- Nivel de log del AM (por si quieres ver más detalle en logs) -->
    <property>
        <name>tez.am.log.level</name>
        <value>INFO</value>
    </property>

</configuration>
