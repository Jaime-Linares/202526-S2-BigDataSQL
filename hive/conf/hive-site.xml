<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ===================== -->
    <!--  GENERAL / EJECUCIÓN  -->
    <!-- ===================== -->

    <!-- No hacer doAs (que no intente cambiar al usuario de HDFS) -->
    <property>
        <name>hive.server2.enable.doAs</name>
        <value>false</value>
    </property>

    <!-- Directorio de scratch en HDFS (relativo a fs.defaultFS, que viene de core-site.xml) -->
    <property>
        <name>hive.exec.scratchdir</name>
        <value>/tmp/hive/scratch</value>
    </property>

    <!-- Scratch local en cada contenedor (filesystem local del pod/contenedor) -->
    <property>
        <name>hive.exec.local.scratchdir</name>
        <value>/tmp/hive/local</value>
    </property>

    <!-- Directorio de staging en HDFS para operaciones de escritura -->
    <property>
        <name>hive.exec.stagingdir</name>
        <value>/.hive-staging</value>
    </property>

    <property>
        <name>hive.user.install.directory</name>
        <value>/opt/hive/install_dir</value>
    </property>

    <property>
        <name>hive.exec.submit.local.task.via.child</name>
        <value>false</value>
    </property>

    <property>
        <name>hive.compactor.worker.threads</name>
        <value>1</value>
    </property>

    <!-- ====================== -->
    <!--  METASTORE: MySQL      -->
    <!-- ====================== -->

    <property>
        <name>javax.jdo.option.ConnectionURL</name>
        <value>jdbc:mysql://mysql:3306/metastore_db?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC</value>
    </property>

    <property>
        <name>javax.jdo.option.ConnectionDriverName</name>
        <value>com.mysql.cj.jdbc.Driver</value>
    </property>

    <property>
        <name>javax.jdo.option.ConnectionUserName</name>
        <value>hive</value>
    </property>

    <property>
        <name>javax.jdo.option.ConnectionPassword</name>
        <value>password</value>
    </property>

    <property>
        <name>hive.metastore.uris</name>
        <value>thrift://metastore:9083</value>
    </property>

    <property>
        <name>metastore.metastore.event.db.notification.api.auth</name>
        <value>false</value>
    </property>

    <!-- Warehouse EN HDFS (fs.defaultFS = hdfs://namenode:9000 en core-site.xml) -->
    <property>
        <name>hive.metastore.warehouse.dir</name>
        <value>/user/hive/warehouse</value>
    </property>

    <!-- ====================== -->
    <!--  MOTOR DE EJECUCIÓN    -->
    <!-- ====================== -->

    <!-- Usar TEZ como engine -->
    <property>
        <name>hive.execution.engine</name>
        <value>tez</value>
    </property>

    <!-- Ajustes suaves para contenedores Tez (puedes afinarlos luego) -->
    <property>
        <name>hive.tez.container.size</name>
        <value>512</value>
    </property>

    <property>
        <name>hive.tez.java.opts</name>
        <value>-Xmx384m</value>
    </property>

    <!-- ====================== -->
    <!--  HIVESERVER2           -->
    <!-- ====================== -->

    <property>
        <name>hive.server2.thrift.port</name>
        <value>10000</value>
    </property>

    <property>
        <name>hive.server2.authentication</name>
        <value>NONE</value>
    </property>

    <!-- ====================== -->
    <!--  FORMATOS y PARÁMETROS -->
    <!-- ====================== -->

    <!-- Formato por defecto -->
    <property>
        <name>hive.default.fileformat</name>
        <value>Parquet</value>
    </property>

    <!-- Forzar formato Parquet en managed tables -->
    <property>
        <name>hive.default.fileformat.managed</name>
        <value>Parquet</value>
    </property>

    <property>
        <name>hive.exec.dynamic.partition.mode</name>
        <value>nonstrict</value>
    </property>

    <property>
        <name>hive.exec.max.dynamic.partitions</name>
        <value>1000</value>
    </property>

    <property>
        <name>hive.exec.max.dynamic.partitions.pernode</name>
        <value>1000</value>
    </property>

    <property>
        <name>hive.exec.compress.output</name>
        <value>true</value>
    </property>

    <property>
        <name>parquet.compression</name>
        <value>SNAPPY</value>
    </property>

</configuration>
